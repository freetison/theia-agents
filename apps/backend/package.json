{
  "name": "@theia/backend",
  "version": "1.0.0",
  "description": "Theia NestJS API — HTTP/SSE layer over the multi-agent engine.",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "tsx --tsconfig tsconfig.json src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx --tsconfig tsconfig.json src/database/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^8.0.0",
    "@theia-core/config": "^2.0.24",
    "@theia-core/logging": "^1.0.0",
    "@theia-core/nestjs-core": "^1.0.5",
    "@theia-core/result": "^1.2.0",
    "@theia/engine": "workspace:*",
    "drizzle-orm": "^0.41.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
