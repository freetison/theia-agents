# Dev-mode backend — mirrors local `pnpm --filter @theia/backend dev`
# Uses tsx so @theia/engine .ts exports resolve correctly (no separate engine build needed)
FROM node:20-alpine

RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /app

# Write .npmrc with the actual token value (ARG is shell-expanded in RUN, not in COPY)
ARG GITHUB_TOKEN
RUN printf "@theia-core:registry=https://npm.pkg.github.com/\n//npm.pkg.github.com/:_authToken=%s\nauto-install-peers=false\n" "$GITHUB_TOKEN" > .npmrc

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/engine/package.json ./packages/engine/
COPY apps/backend/package.json ./apps/backend/

RUN pnpm install --no-frozen-lockfile

COPY packages/ ./packages/
COPY apps/backend/ ./apps/backend/

EXPOSE 3000

ENV NODE_ENV=development

CMD ["pnpm", "--filter", "@theia/backend", "dev"]
