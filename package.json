{
  "name": "theia-agents",
  "version": "2.0.0-alpha.0",
  "private": true,
  "description": "Theia multi-agent platform — monorepo root",
  "type": "module",
  "scripts": {
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "start": "pnpm --filter @theia/cli start",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10"
  },
  "lint-staged": {
    "**/src/**/*.ts": [
      "pnpm --filter @theia/engine test"
    ]
  }
}
